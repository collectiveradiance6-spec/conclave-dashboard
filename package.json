{
  "name": "conclave-aegis-api",
  "version": "9.0.0",
  "description": "TheConclave Dominion — AEGIS Backend API + Bot",
  "main": "server.js",
  "scripts": {
    "start":       "node server.js",
    "dev":         "node --watch server.js",
    "bot":         "node bot.js",
    "check":       "node --check server.js && node --check bot.js",
    "lint":        "npx eslint server.js bot.js --no-eslintrc -c '{\"env\":{\"node\":true,\"es2022\":true}}' || true"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk":    "^0.39.0",
    "@supabase/supabase-js": "^2.47.0",
    "axios":                "^1.7.0",
    "cors":                 "^2.8.5",
    "discord.js":           "^14.16.0",
    "dotenv":               "^16.4.0",
    "express":              "^4.21.0",
    "express-session":      "^1.18.0",
    "jsonwebtoken":         "^9.0.2",
    "multer":               "^1.4.5-lts.1"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
